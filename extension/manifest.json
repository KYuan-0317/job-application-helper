{
  "manifest_version": 3,
  "name": "Job Application Helper",
  "version": "0.4.2",
  "description": "Generate tailored cover letters and job application answers from a resume and job description.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8787/*"
  ],
  "action": {
    "default_title": "Open Job Application Helper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
